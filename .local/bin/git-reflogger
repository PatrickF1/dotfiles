#!/usr/bin/env fish

# Fuzzy selector for git reflog entries with commit preview
# Needs to be put in your path and made executable for git to find it.
# See https://www.atlassian.com/git/articles/extending-git for more info.
# Usage:
#    git reflogger
if not git rev-parse --git-dir >/dev/null 2>&1
    echo 'Not in a git repository.' >&2
    exit 1
else if [ (count $argv) -gt 0 ]
    echo 'git-reflogger does not take any arguments.' >&2
    exit 1
else if not type -q fzf
    echo "You must have fzf (https://github.com/junegunn/fzf) installed." >&2
    echo "If you are on Mac and use homebrew, try 'brew install fzf'" >&2
    exit 1
end

# see documentation for git format placeholders at https://git-scm.com/docs/git-log#Documentation/git-log.txt-emnem
# %h: abbreviated commit hash (we'll expand it later)
# %gd: reflog selector. With --date=relative this renders as HEAD@{N ago}, which is
#      the time of the reflog action itself (e.g. when the reset happened), not the
#      committer date of the commit it points to. That's what you need for recovery.
# %gs: reflog subject -- the action that produced this entry (commit, commit (amend),
#      reset, rebase, checkout, ...). Critical signal for spotting destructive ops.
# %s: subject of the commit this entry points to. For non-commit actions (reset,
#     checkout, rebase) this reveals the content of the commit at that HEAD position,
#     which %gs alone doesn't tell you.
set selected_reflog_line (
    git reflog --date=relative --color=always \
        --format=format:'%C(bold blue)%h%C(reset) %C(green)%gd%C(reset)  %C(yellow)%gs%C(reset)  %C(dim normal)%s%C(reset)' | \
    fzf --ansi --tiebreak=index \
        --preview='git show --color=always --stat --patch {1}'
)

if [ -z $selected_reflog_line ]
    echo 'Cancelled.' >&2
    exit 2
end

set abbreviated_commit_hash (string split --max 1 " " $selected_reflog_line)[1]
set commit_hash (git rev-parse $abbreviated_commit_hash)

printf "%s" "$commit_hash" | pbcopy
echo "Commit hash copied to clipboard ($commit_hash)"
